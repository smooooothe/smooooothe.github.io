---
import { getFeaturedProject } from "../data/localizedProjects";
import { translations } from "../data/translations";
import type { Language } from "../data/translations";

interface Props {
  lang?: Language;
}

const { lang = "ru" } = Astro.props;
const t = translations[lang];
const featured = getFeaturedProject(lang);
---

<section id="featured" class="section-shell border-t-0" aria-labelledby="featured-heading">
  <header class="section-header scroll-reveal">
    <span class="section-number">{t.featured.sectionNumber}</span>
    <div>
      <p class="section-kicker">{t.featured.kicker}</p>
      <h2 id="featured-heading" class="section-title">{t.featured.title}</h2>
    </div>
  </header>

  <article id="work-mwcc" class="ui-panel scroll-reveal grid overflow-hidden lg:grid-cols-[1.4fr_1fr]">
    <div class="border-b border-[var(--color-line)] p-4 sm:p-6 lg:border-b-0 lg:border-r">
      <figure class="ui-panel overflow-hidden">
        {
          featured.thumbnail ? (
            <img
              src={featured.thumbnail.src}
              alt={featured.thumbnail.alt}
              class="aspect-[16/9] w-full object-cover"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="aspect-[16/9] w-full bg-surface-2" aria-hidden="true" />
          )
        }
      </figure>
      {featured.thumbnail?.disclosure && <p class="mt-3 text-xs text-dim">{featured.thumbnail.disclosure}</p>}

      <div class="mt-5 grid gap-3 sm:grid-cols-2">
        <div class="ui-card p-4">
          <p class="font-mono text-[11px] uppercase tracking-[0.13em] text-dim">{t.featured.problem}</p>
          <p class="mt-2 text-sm">{featured.problem}</p>
        </div>
        <div class="ui-card p-4">
          <p class="font-mono text-[11px] uppercase tracking-[0.13em] text-dim">{t.featured.outcome}</p>
          <p class="mt-2 text-sm">{featured.outcome}</p>
        </div>
      </div>
    </div>

    <div class="grid content-between p-4 sm:p-6">
      <div>
        <p class="ui-badge">{t.featured.primaryCase}</p>
        <h3 class="mt-4 font-display text-[clamp(1.8rem,3.2vw,3rem)] leading-[0.95]">{featured.title}</h3>
        <p class="mt-3 text-dim">{featured.tagline}</p>
        <p class="mt-5 font-mono text-[11px] uppercase tracking-[0.13em] text-dim">{t.featured.role}</p>
        <p class="mt-1 text-sm">{featured.role}</p>

        <p class="mt-5 font-mono text-[11px] uppercase tracking-[0.13em] text-dim">{t.featured.stack}</p>
        <div class="mt-2 flex flex-wrap gap-2">
          {featured.stack.map((item) => <span class="ui-badge">{item}</span>)}
        </div>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        {
          featured.links?.map((link) => (
            <a href={link.href} class="ui-btn ui-btn-ghost">
              {link.label === "Live site" ? t.featured.liveSite : link.label}
            </a>
          ))
        }
      </div>
    </div>
  </article>
</section>
