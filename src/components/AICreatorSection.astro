---
import { aiCreatorCards } from "../data/projects";
import { site } from "../data/site";
import { translations } from "../data/translations";
import type { Language } from "../data/translations";

interface Props {
  lang?: Language;
}

const { lang = "ru" } = Astro.props;
const t = translations[lang];

const higgsfieldPieces = [
  {
    label: "Ember Coffee — local-business ad",
    concept: "Vertical ad · hook → offer → CTA",
    engine: "Higgsfield · Seedance 2.0",
    detail:
      "A 5-shot ad for a local café: a cozy-shop hook, product beats, and a \u201cyou're 3 minutes away\u201d offer with on-screen subtitles + CTA. Voiceover ducked over an ambience bed. Self-scored 94.",
    src: "/media/ai-creator/tz1-ember-coffee.mp4",
    poster: "/media/ai-creator/tz1-ember-coffee.jpg",
    meta: "9:16 · 28s · 5 shots",
  },
  {
    label: "NOIR \u00c9CLAT — cinematic product",
    concept: "Cinematic product · luxury grade",
    engine: "Higgsfield · Seedance 2.0",
    detail:
      "Six product keyframes held rock-stable across every angle, then dolly / orbit / push-in i2v. Shipped in two color grades (Warm Gold / Cool Noir), two aspect ratios, plus a social cut — bed + VO. Self-scored 95.",
    src: "/media/ai-creator/tz2-noir-eclat.mp4",
    poster: "/media/ai-creator/tz2-noir-eclat.jpg",
    meta: "9:16 · 16s · luxury grade",
  },
  {
    label: "Sharp & Co. — consistent character",
    concept: "Consistent character · identity hold",
    engine: "Higgsfield · keyframe-locked i2v",
    detail:
      "One barber carried across a 5-scene real-shop ad via keyframe identity lock — face and wardrobe stay consistent shot-to-shot. Voiceover + ambience bed. Self-scored 95.",
    src: "/media/ai-creator/tz3-sharp-co.mp4",
    poster: "/media/ai-creator/tz3-sharp-co.jpg",
    meta: "9:16 · 25s · 5 scenes",
  },
  {
    label: "AETHER — logo reveal / motion design",
    concept: "Motion design · kinetic logo reveal",
    engine: "Higgsfield plates \u2192 deterministic type",
    detail:
      "Hybrid reveal: Higgsfield energy plates driven to motion, with razor-sharp deterministic kinetic typography and designed sound (whoosh \u2192 impact \u2192 drone). Loop-friendly, 9:16 + 16:9, solid + transparent end cards. Self-scored 94.",
    src: "/media/ai-creator/tz4-aether-logo.mp4",
    poster: "/media/ai-creator/tz4-aether-logo.jpg",
    meta: "9:16 · 9s · 2 ARs",
  },
] as const;

const comfyPieces = [
  {
    label: "AURELIA — image-to-video",
    concept: "i2v motion · variant selection",
    engine: "Comfy Cloud · Seedance i2v",
    detail:
      "A still hero driven to motion across 3 camera variants (the push-in won the cut). Tailored stable-audio-2.5 bed + tagline VO. Self-scored 91.",
    src: "/media/ai-creator/tz5-aurelia.mp4",
    poster: "/media/ai-creator/tz5-aurelia.jpg",
    meta: "16:9 · 8s",
    ratio: "16 / 9",
  },
  {
    label: "Pedestal Reveal — first / last frame",
    concept: "First \u2192 last frame control",
    engine: "Comfy Cloud · Seedance first/last",
    detail:
      "A controlled product reveal driven by locked first and last keyframes for an exact end state — not a hope-and-pray prompt. Bed + reveal VO. Self-scored 88.",
    src: "/media/ai-creator/tz6-pedestal-reveal.mp4",
    poster: "/media/ai-creator/tz6-pedestal-reveal.jpg",
    meta: "16:9 · 5s",
    ratio: "16 / 9",
  },
  {
    label: "Fashion-House Identity Lock — consistency ad",
    concept: "One woman · 3 looks · 2 locations",
    engine: "Comfy Cloud · nano-banana refs + seedance i2v",
    detail:
      "A premium fashion-house film built to prove identity: a new character generated on a strong model and locked as a canonical hero, holding across three wardrobe changes in one apartment and two further locations. Voiceover + stable-audio score, no subtitles. Ships with a consistency proof grid.",
    src: "/media/ai-creator/tz7-character.mp4",
    poster: "/media/ai-creator/tz7-character.jpg",
    meta: "9:16 · 17s",
    ratio: "9 / 16",
  },
  {
    label: "VOLT — modular campaign",
    concept: "Modular campaign · one reusable graph",
    engine: "Comfy Cloud · single reusable workflow",
    detail:
      "A 3-part vertical campaign — hook (6s) / demo (10s) / CTA (8s) — from one reusable workflow with shared sonic branding. Demo shown here; 3 covers + an asset\u2192goal\u2192CTA table ship with it. Self-scored 89.",
    src: "/media/ai-creator/tz8-volt-campaign.mp4",
    poster: "/media/ai-creator/tz8-volt-campaign.jpg",
    meta: "9:16 · hook / demo / CTA",
    ratio: "9 / 16",
  },
] as const;

const flagshipFilms = [
  {
    label: "SIGNAL",
    tagline: "FictioFactori brand film — \u201cwe build the signal\u201d",
    concept: "Cinematic · directed multi-shot · identity continuity",
    engine: "Higgsfield · GPT Image 2 → Nano Banana 2 → Seedance 2.0",
    pipeline:
      "3-stage keyframe lock: a GPT Image 2 hero keyframe → per-shot Nano Banana 2 keyframes (hero passed as reference) → Seedance 2.0 i2v. The Architect's identity and the acid-lime shard hold across all 5 directed shots with zero re-rolls. Final cut scored with a voiceover ducked over a music bed.",
    src: "/media/ai-creator/flagship-signal-higgsfield.mp4",
    poster: "/media/ai-creator/flagship-signal-higgsfield.jpg",
    meta: "9:16 · 25s · 5 shots · scored",
    ratio: "9 / 16",
  },
  {
    label: "NOVA — Signal in the Noise",
    tagline: "Character brand-film — consistency pipeline",
    concept: "Character lock · reference-edit pipeline · 4-shot arc",
    engine: "Comfy Cloud · Nano Banana keyframes → Seedance i2v → assemble.py",
    pipeline:
      "One canonical hero keyframe, then 3 angle/expression keyframes edited from the original hero (never chained) to kill drift. Identity holds 4/4 shots; the continuity-object pendant evolves dark → blaze across the cut. Final cut scored with a 4-line voiceover over a synthwave bed.",
    src: "/media/ai-creator/flagship-nova-comfy.mp4",
    poster: "/media/ai-creator/flagship-nova-comfy.jpg",
    meta: "16:9 · 16s · 4 shots · scored",
    ratio: "16 / 9",
  },
] as const;
---

<section
  id="ai-creator"
  class="section-shell"
  aria-labelledby="ai-creator-heading"
>
  <header class="section-header scroll-reveal">
    <span class="section-number">{t.aiCreator.sectionNumber}</span>
    <div>
      <p class="section-kicker">{t.aiCreator.kicker}</p>
      <h2 id="ai-creator-heading" class="section-title">{t.aiCreator.title}</h2>
    </div>
  </header>

  <div>
    <div class="scroll-reveal mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-2xl">
        <p class="text-dim">
          {t.aiCreator.description}
        </p>
      </div>
      <a href={site.contactHref} target="_blank" rel="noopener noreferrer" class="ui-btn ui-btn-ghost shrink-0">
        {t.aiCreator.requestLogs}
      </a>
    </div>

    <div class="scroll-reveal mb-4">
      <p class="section-kicker">{t.aiCreator.flagshipFilms}</p>
      <h3 class="text-[clamp(1.6rem,2.8vw,2.7rem)] leading-[0.95]">{t.aiCreator.flagshipTitle}</h3>
      <p class="mt-2 text-sm text-dim">
        {t.aiCreator.flagshipDescription}
      </p>
    </div>

    <div class="scroll-reveal mb-12 grid gap-4 lg:grid-cols-2">
      {
        flagshipFilms.map((clip) => (
          <figure class="ui-card flex flex-col p-3">
            <video
              class="mx-auto w-full max-w-[420px] border border-[var(--color-line)] bg-black/30 object-cover"
              style={`aspect-ratio:${clip.ratio}`}
              poster={clip.poster}
              controls
              aria-label={clip.label}
              playsinline
              preload="none"
            >
              <source src={clip.src} type="video/mp4" />
            </video>
            <figcaption class="mt-3 flex flex-1 flex-col">
              <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-acid">{clip.concept}</p>
              <p class="mt-1 text-lg leading-tight">{clip.label}</p>
              <p class="mt-0.5 text-sm text-dim">{clip.tagline}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em] text-dim">{clip.engine} · {clip.meta}</p>
              <p class="mt-2 text-xs leading-relaxed text-dim">{clip.pipeline}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <div class="scroll-reveal mb-4">
      <p class="section-kicker">{t.aiCreator.higgsfieldTitle}</p>
      <h3 class="text-[clamp(1.6rem,2.8vw,2.7rem)] leading-[0.95]">{t.aiCreator.higgsfieldSubtitle}</h3>
      <p class="mt-2 text-sm text-dim">
        {t.aiCreator.higgsfieldDescription}
      </p>
    </div>

    <div class="scroll-reveal mb-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        higgsfieldPieces.map((clip) => (
          <figure class="ui-card flex flex-col p-3">
            <video
              class="aspect-[9/16] w-full border border-[var(--color-line)] bg-black/30 object-cover"
              poster={clip.poster}
              controls
              aria-label={clip.label}
              playsinline
              preload="none"
            >
              <source src={clip.src} type="video/mp4" />
            </video>
            <figcaption class="mt-3 flex flex-1 flex-col">
              <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-acid">{clip.concept}</p>
              <p class="mt-1 text-sm">{clip.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em] text-dim">{clip.engine} · {clip.meta}</p>
              <p class="mt-2 text-xs leading-relaxed text-dim">{clip.detail}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <div class="scroll-reveal mb-4">
      <p class="section-kicker">{t.aiCreator.comfyTitle}</p>
      <h3 class="text-[clamp(1.6rem,2.8vw,2.7rem)] leading-[0.95]">{t.aiCreator.comfySubtitle}</h3>
      <p class="mt-2 text-sm text-dim">
        {t.aiCreator.comfyDescription}
      </p>
    </div>

    <div class="scroll-reveal mb-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        comfyPieces.map((clip) => (
          <figure class="ui-card flex flex-col p-3">
            <video
              class="mx-auto max-h-[360px] w-full border border-[var(--color-line)] bg-black/30 object-cover"
              style={`aspect-ratio:${clip.ratio}`}
              poster={clip.poster}
              controls
              aria-label={clip.label}
              playsinline
              preload="none"
            >
              <source src={clip.src} type="video/mp4" />
            </video>
            <figcaption class="mt-3 flex flex-1 flex-col">
              <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-acid">{clip.concept}</p>
              <p class="mt-1 text-sm">{clip.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em] text-dim">{clip.engine} · {clip.meta}</p>
              <p class="mt-2 text-xs leading-relaxed text-dim">{clip.detail}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <article class="ui-card scroll-reveal flex flex-col p-6">
        <span class="font-mono text-[10px] uppercase tracking-wider text-dim">{t.aiCreator.creatorCards.contentLab.status}</span>
        <h3 class="mt-2 text-[1.8rem] leading-[0.95]">{t.aiCreator.creatorCards.contentLab.title}</h3>
        <p class="mt-3 flex-1 text-sm leading-relaxed text-dim">{t.aiCreator.creatorCards.contentLab.description}</p>
        <p class="mt-6 font-mono text-xs uppercase tracking-wider text-acid/80">
          {lang === "ru" ? "Evidence-first creator system" : "Evidence-first creator system"}
        </p>
      </article>
      <article class="ui-card scroll-reveal flex flex-col p-6">
        <span class="font-mono text-[10px] uppercase tracking-wider text-dim">{t.aiCreator.creatorCards.workflowDemos.status}</span>
        <h3 class="mt-2 text-[1.8rem] leading-[0.95]">{t.aiCreator.creatorCards.workflowDemos.title}</h3>
        <p class="mt-3 flex-1 text-sm leading-relaxed text-dim">{t.aiCreator.creatorCards.workflowDemos.description}</p>
        <p class="mt-6 font-mono text-xs uppercase tracking-wider text-acid/80">
          {lang === "ru" ? "Evidence-first creator system" : "Evidence-first creator system"}
        </p>
      </article>
      <article class="ui-card scroll-reveal flex flex-col p-6">
        <span class="font-mono text-[10px] uppercase tracking-wider text-dim">{t.aiCreator.creatorCards.tooling.status}</span>
        <h3 class="mt-2 text-[1.8rem] leading-[0.95]">{t.aiCreator.creatorCards.tooling.title}</h3>
        <p class="mt-3 flex-1 text-sm leading-relaxed text-dim">{t.aiCreator.creatorCards.tooling.description}</p>
        <p class="mt-6 font-mono text-xs uppercase tracking-wider text-acid/80">
          {lang === "ru" ? "Evidence-first creator system" : "Evidence-first creator system"}
        </p>
      </article>
    </div>
  </div>
</section>
