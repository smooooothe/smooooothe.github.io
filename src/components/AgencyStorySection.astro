---
import { translations } from "../data/translations";
import type { Language } from "../data/translations";

interface Props {
  lang?: Language;
}

const { lang = "ru" } = Astro.props;
const t = translations[lang];
---

<section
  id="ai-agency"
  class="section-shell"
  aria-labelledby="ai-agency-heading"
>
  <header class="section-header scroll-reveal">
    <span class="section-number">{t.agency.sectionNumber}</span>
    <div>
      <p class="section-kicker">{t.agency.kicker}</p>
      <h2 id="ai-agency-heading" class="section-title">{t.agency.title}</h2>
    </div>
  </header>
  <div class="scroll-reveal grid gap-4 lg:grid-cols-[1.2fr_1fr]">
    <article
      class="ui-panel p-5 sm:p-6"
      style="background-image: linear-gradient(rgba(10,12,14,0.82), rgba(10,12,14,0.82)), url('/media/portfolio/texture-concrete-plastic-atlas.webp'); background-size: cover; background-position: center;"
    >
      <p class="text-dim">
        {lang === "ru"
          ? "Эта операционная модель была построена в процессе активной recovery-работы. Цель была не 'больше доков', а live delivery system, где каждый поток имеет явное владение, QA-гейты и верифицируемые артефакты."
          : "This operating model was built during active recovery work. The target was not 'more docs', but a live delivery system where every stream has explicit ownership, QA gates, and verifiable artifacts."}
      </p>
      <div class="mt-4 grid gap-3 sm:grid-cols-3">
        <div class="ui-card p-3 text-sm">
          <p class="font-mono text-[11px] uppercase tracking-[0.13em] text-dim">{t.agency.problem}</p>
          <p class="mt-2">{t.agency.problemText}</p>
        </div>
        <div class="ui-card p-3 text-sm">
          <p class="font-mono text-[11px] uppercase tracking-[0.13em] text-dim">{t.agency.approach}</p>
          <p class="mt-2">{t.agency.approachText}</p>
        </div>
        <div class="ui-cta p-3 text-sm">
          <p class="font-mono text-[11px] uppercase tracking-[0.13em]">{t.agency.outcome}</p>
          <p class="mt-2">{t.agency.outcomeText}</p>
        </div>
      </div>
    </article>
    <article class="ui-panel p-5 sm:p-6">
      <p class="section-kicker">{t.agency.operatingOutputs}</p>
      <ul class="space-y-2 text-sm text-dim">
        {t.agency.outputs.map((item) => (
          <li>• {item}</li>
        ))}
      </ul>
    </article>
  </div>
</section>
