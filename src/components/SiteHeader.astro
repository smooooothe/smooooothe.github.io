---
import { site } from "../data/site";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import type { Language } from "../data/translations";
import { translations } from "../data/translations";

interface Props {
  lang?: Language;
}

const { lang = "ru" } = Astro.props;
const t = translations[lang];
---

<header class="ui-nav sticky top-0 z-40">
  <div class="mx-auto flex w-full max-w-[90rem] items-center justify-between gap-5 px-4 py-3 sm:px-6 lg:px-8">
    <a href="/" class="font-display text-[1.7rem] leading-none tracking-tight transition hover:text-acid" aria-label={`${site.name} home`}>
      {site.name}
    </a>

    <nav class="hidden items-center gap-6 font-mono text-[11px] uppercase tracking-[0.14em] text-dim lg:flex" aria-label="Primary">
      <a href="#featured" class="transition hover:text-acid">{t.nav.flagship}</a>
      <a href="#case-studies" class="transition hover:text-acid">{t.nav.caseStudies}</a>
      <a href="#work" class="transition hover:text-acid">{t.nav.selectedWork}</a>
      <a href="#ai-agency" class="transition hover:text-acid">{t.nav.agencySystem}</a>
      <a href="#ai-creator" class="transition hover:text-acid">{t.nav.aiCreator}</a>
      <a href="#contact" class="transition hover:text-acid">{t.nav.contact}</a>
    </nav>

    <div class="flex items-center gap-3">
      <LanguageSwitcher currentLang={lang} />
      <a
        href={site.github}
        target="_blank"
        rel="noopener noreferrer"
        class="ui-btn ui-btn-ghost hidden sm:inline-flex"
      >
        {t.nav.github}
      </a>
      <a href="#contact-hire" class="ui-btn ui-btn-primary">
        {t.nav.bookIntro}
      </a>
    </div>
  </div>
</header>
