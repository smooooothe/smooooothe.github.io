---
import type { Project } from "../data/projects";
import type { Language } from "../data/translations";

interface Props {
  project: Project;
  lang?: Language;
}

const { project, lang = "ru" } = Astro.props;

const spanClass =
  project.span === "wide"
    ? "md:col-span-2"
    : project.span === "tall"
      ? "md:row-span-2"
      : "";
---

<article
  class={`ui-card scroll-reveal group flex flex-col overflow-hidden ${spanClass}`}
  id={`work-${project.id}`}
>
  <div
    class="relative min-h-[12rem] border-b border-[var(--color-line)] bg-bg-elev"
    style={project.accent ? `--card-accent: ${project.accent}` : undefined}
  >
    {
      project.thumbnail ? (
        <>
          <img
            src={project.thumbnail.src}
            alt={project.thumbnail.alt}
            class="h-56 w-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/80 via-black/35 to-transparent" />
        </>
      ) : (
        <div
          class="h-56 w-full bg-surface-2"
          aria-hidden="true"
        />
      )
    }
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-1.5 opacity-90 transition"
      style={`background: var(--card-accent, #f59e0b)`}
      aria-hidden="true"
    />
    <div class="absolute inset-x-0 bottom-0 p-4 sm:p-5">
      <p class="font-mono text-[11px] uppercase tracking-[0.13em] text-acid">{project.role}</p>
      <h3 class="mt-2 text-[clamp(1.6rem,2.7vw,2.4rem)] leading-[0.95]">{project.title}</h3>
      <p class="mt-1 text-sm text-dim">{project.tagline}</p>
    </div>
  </div>

  <div class="border-t border-[var(--color-line)] p-4 sm:p-5">
    <p class="text-sm font-medium leading-snug">{project.outcome}</p>
    <p class="mt-3 text-xs leading-relaxed text-dim line-clamp-3">{project.problem}</p>
    {
      project.thumbnail?.disclosure && (
        <p class="mt-3 text-[11px] leading-relaxed text-dim">{project.thumbnail.disclosure}</p>
      )
    }
    <ul class="mt-4 flex flex-wrap gap-1.5" aria-label={`${project.title} stack`}>
      {
        project.stack.slice(0, 4).map((item) => (
          <li><span class="ui-badge">{item}</span></li>
        ))
      }
    </ul>
    {
      project.links && project.links.length > 0 && (
        <div class="mt-4">
          {
            project.links.map((link) => (
              <a
                href={link.href}
                class="font-mono text-xs uppercase tracking-[0.12em] text-acid transition hover:underline"
              >
                {link.label} →
              </a>
            ))
          }
        </div>
      )
    }
  </div>
</article>
