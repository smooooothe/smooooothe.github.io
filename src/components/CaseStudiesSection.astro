---
import { getCaseStudies } from "../data/localizedProjects";
import { translations } from "../data/translations";
import type { Language } from "../data/translations";

interface Props {
  lang?: Language;
}

const { lang = "ru" } = Astro.props;
const t = translations[lang];
const caseStudies = getCaseStudies(lang);
---

<section id="case-studies" class="section-shell" aria-labelledby="case-studies-heading">
  <header class="section-header scroll-reveal">
    <span class="section-number">{t.caseStudies.sectionNumber}</span>
    <div>
      <p class="section-kicker">{t.caseStudies.kicker}</p>
      <h2 id="case-studies-heading" class="section-title">{t.caseStudies.title}</h2>
    </div>
  </header>

  <div class="grid gap-5">
    {
      caseStudies.map((study) => (
        <article class="ui-panel scroll-reveal grid overflow-hidden lg:grid-cols-[340px_1fr]">
          <div class="border-b border-[var(--color-line)] p-4 sm:p-5 lg:border-b-0 lg:border-r">
            <p class="section-kicker">{t.caseStudies.caseStudy}</p>
            <h3 class="text-3xl leading-[0.95]">{study.title}</h3>
            <p class="mt-2 text-sm text-dim">{study.tagline}</p>

            <figure class="ui-panel mt-4 overflow-hidden">
              {study.image ? (
                <img
                  src={study.image.src}
                  alt={study.image.alt}
                  class="aspect-[4/3] w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="aspect-[4/3] w-full bg-surface-2" aria-hidden="true" />
              )}
            </figure>
            <p class="mt-2 text-xs text-dim">{study.visual}</p>
            {study.image?.disclosure && <p class="mt-1 text-xs text-dim">{study.image.disclosure}</p>}

            <p class="mt-4 font-mono text-[11px] uppercase tracking-[0.13em] text-dim">{t.caseStudies.role}</p>
            <p class="mt-1 text-sm">{study.role}</p>
          </div>

          <div class="grid gap-3 p-4 sm:grid-cols-2 sm:p-5">
            <div class="ui-card p-4">
              <p class="font-mono text-[11px] uppercase tracking-[0.13em] text-dim">{t.caseStudies.context}</p>
              <p class="mt-2 text-sm">{study.problem.context}</p>
            </div>
            <div class="ui-card p-4">
              <p class="font-mono text-[11px] uppercase tracking-[0.13em] text-dim">{t.caseStudies.stakes}</p>
              <p class="mt-2 text-sm">{study.problem.stakes}</p>
            </div>

            <div class="ui-card p-4 sm:col-span-2">
              <p class="font-mono text-[11px] uppercase tracking-[0.13em] text-dim">{t.caseStudies.approach}</p>
              <ul class="mt-2 space-y-1 text-sm">
                {study.approach.map((item) => <li>• {item}</li>)}
              </ul>
            </div>

            <div class="ui-card p-4 sm:col-span-2">
              <p class="font-mono text-[11px] uppercase tracking-[0.13em] text-dim">{t.caseStudies.built}</p>
              <ul class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
                {study.built.map((item) => <li>• {item}</li>)}
              </ul>
            </div>

            <div class="ui-cta p-4 sm:col-span-2">
              <p class="font-mono text-[11px] uppercase tracking-[0.13em]">{t.caseStudies.outcomeLabel}</p>
              <ul class="mt-2 space-y-1 text-sm">
                {study.outcome.map((item) => <li>• {item}</li>)}
              </ul>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
