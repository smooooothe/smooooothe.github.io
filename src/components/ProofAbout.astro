---
import { site } from "../data/site";
import { translations } from "../data/translations";
import type { Language } from "../data/translations";

interface Props {
  lang?: Language;
}

const { lang = "ru" } = Astro.props;
const t = translations[lang];
---

<section
  id="about"
  class="section-shell"
  aria-labelledby="about-heading"
>
  <header class="section-header scroll-reveal">
    <span class="section-number">{t.about.sectionNumber}</span>
    <div>
      <p class="section-kicker">{t.about.kicker}</p>
      <h2 id="about-heading" class="section-title">{t.about.title}</h2>
    </div>
  </header>

  <div class="grid gap-5 lg:grid-cols-2">
    <div class="ui-panel scroll-reveal p-5 sm:p-6">
      <p class="leading-relaxed text-dim">
        {t.about.builderDescription[0]}
      </p>
      <p class="mt-4 leading-relaxed text-dim">
        {t.about.builderDescription[1]}
      </p>
      <p class="mt-4 text-sm text-dim">
        {t.about.builderDescription[2]}
        <span>{t.about.tbd}</span>
      </p>
    </div>

    <div class="space-y-4">
      <figure class="ui-card scroll-reveal p-6">
        <blockquote class="text-[1.85rem] leading-[0.95]">
          {t.about.quote}
        </blockquote>
        <figcaption class="mt-4 text-sm text-dim">
          {t.about.quoteCaption}
        </figcaption>
      </figure>

      <div class="ui-card scroll-reveal p-6">
        <h3 class="font-mono text-xs uppercase tracking-wider text-dim">{t.about.capabilities}</h3>
        <dl class="mt-4 grid gap-4 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-medium">{t.about.capabilitiesList.ai.title}</dt>
            <dd class="mt-1 text-sm text-dim">{t.about.capabilitiesList.ai.desc}</dd>
          </div>
          <div>
            <dt class="text-sm font-medium">{t.about.capabilitiesList.backend.title}</dt>
            <dd class="mt-1 text-sm text-dim">{t.about.capabilitiesList.backend.desc}</dd>
          </div>
          <div>
            <dt class="text-sm font-medium">{t.about.capabilitiesList.frontend.title}</dt>
            <dd class="mt-1 text-sm text-dim">{t.about.capabilitiesList.frontend.desc}</dd>
          </div>
          <div>
            <dt class="text-sm font-medium">{t.about.capabilitiesList.product.title}</dt>
            <dd class="mt-1 text-sm text-dim">{t.about.capabilitiesList.product.desc}</dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>

<section id="proof" class="section-shell border-t-0 border-b-0 pb-8 pt-0" aria-label="Social proof">
  <div class="scroll-reveal grid gap-4 sm:grid-cols-3">
    <div class="ui-cta p-6 text-center">
      <p class="text-2xl">{t.about.proof.commercialValue}</p>
      <p class="mt-2 font-mono text-xs uppercase tracking-wider text-dim">{t.about.proof.commercial}</p>
    </div>
    <div class="ui-cta p-6 text-center">
      <p class="text-2xl">{t.about.proof.scaleValue}</p>
      <p class="mt-2 font-mono text-xs uppercase tracking-wider text-dim">{t.about.proof.scale}</p>
    </div>
    <div class="ui-cta p-6 text-center">
      <p class="text-2xl">{t.about.proof.scopeValue}</p>
      <p class="mt-2 font-mono text-xs uppercase tracking-wider text-dim">{t.about.proof.scope}</p>
    </div>
  </div>
</section>
